{
  "name": "codingpt",
  "version": "0.0.4",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "android:local": "cross-env ENVFILE=.env.local npx react-native run-android log-android",
    "android:dev": "cross-env ENVFILE=.env.dev npx react-native run-android log-android",
    "android:stg": "cross-env ENVFILE=.env.stg npx react-native run-android log-android",
    "android:prod": "cross-env ENVFILE=.env npx react-native run-android log-android",
    "ios-simulator-iphone:local": "cross-env ENVFILE=.env.local npx react-native run-ios log-ios --simulator=\"iPhone 16 Pro\"",
    "ios:local": "cross-env ENVFILE=.env.local npx react-native run-ios log-ios",
    "ios:dev": "cross-env ENVFILE=.env.dev npx react-native run-ios log-ios",
    "ios:stg": "cross-env ENVFILE=.env.stg npx react-native run-ios log-ios",
    "ios:prod": "cross-env ENVFILE=.env npx react-native run-ios log-ios",
    "build:android-apk": "cd android && ./gradlew assembleRelease",
    "build:android-aab": "cd android && ./gradlew bundleRelease",
    "build:android-clean": "cd android && ./gradlew clean",
    "build:ios-archive": "cd ios && xcodebuild -workspace codingpt.xcworkspace -scheme codingpt -configuration Release -destination generic/platform=iOS -archivePath build/codingpt.xcarchive archive",
    "build:ios-ipa": "cd ios && xcodebuild -exportArchive -archivePath build/codingpt.xcarchive -exportPath build/ipa -exportOptionsPlist exportOptions.plist",
    "build:ios-clean": "cd ios && xcodebuild clean"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-documents/picker": "^12.0.1",
    "@react-native-firebase/app": "^25.1.0",
    "@react-native-firebase/messaging": "^25.1.0",
    "@react-native-google-signin/google-signin": "^15.0.0",
    "@react-native/new-app-screen": "0.80.2",
    "@react-navigation/bottom-tabs": "^7.4.7",
    "@react-navigation/native-stack": "^7.3.24",
    "axios": "^1.10.0",
    "date-fns": "^4.1.0",
    "lottie-react-native": "^7.3.4",
    "moti": "^0.30.0",
    "nativewind": "^4.1.23",
    "phosphor-react-native": "^2.3.1",
    "react": "19.1.0",
    "react-native": "0.80.2",
    "react-native-blob-util": "^0.24.9",
    "react-native-bootsplash": "^6.3.10",
    "react-native-circular-progress": "^1.4.1",
    "react-native-config": "^1.5.5",
    "react-native-device-info": "^15.0.2",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-haptic-feedback": "^2.3.4",
    "react-native-image-picker": "^8.2.1",
    "react-native-inappbrowser-reborn": "^3.7.1",
    "react-native-markdown-display": "^7.0.2",
    "react-native-pager-view": "^6.9.1",
    "react-native-purchases": "^8.12.0",
    "react-native-reanimated": "^3.19.5",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "^4.16.0",
    "react-native-svg": "^15.12.0",
    "react-native-video": "^6.16.1",
    "react-native-view-shot": "^4.0.3",
    "react-native-webview": "^13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@bam.tech/react-native-make": "^3.0.3",
    "@react-native-community/cli": "19.1.1",
    "@react-native-community/cli-platform-android": "19.1.1",
    "@react-native-community/cli-platform-ios": "19.1.1",
    "@react-native/babel-preset": "0.80.2",
    "@react-native/eslint-config": "0.80.2",
    "@react-native/metro-config": "0.80.2",
    "@react-native/typescript-config": "0.80.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "prettier-plugin-tailwindcss": "^0.2.8",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
